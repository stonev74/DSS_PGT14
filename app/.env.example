# App runtime variables
# Copy this file to app/.env and fill in real values.

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
APP_URL=http://localhost:3000

# Postgres connection used by app/db.js
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=blogapp
POSTGRES_ADMIN_USER=blogapp_admin
POSTGRES_ADMIN_PASSWORD=adminpassword
POSTGRES_USER=blogapp_user
POSTGRES_PASSWORD=blogpassword

# Session
SESSION_SECRET=replace-with-a-long-random-string
