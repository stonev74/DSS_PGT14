# Docker Compose variables (repository root)
# Copy this file to .env before running docker compose up.

POSTGRES_DB=blogapp
DB_SUPER_USER=blogapp
DB_SUPER_PASSWORD=blogapp_password

# App container DB credentials (used by app/db.js)
POSTGRES_ADMIN_USER=blogapp_admin
POSTGRES_ADMIN_PASSWORD=adminpassword
APP_POSTGRES_USER=blogapp_user
APP_POSTGRES_PASSWORD=blogpassword
DB_PORT=5432
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
